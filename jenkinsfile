pipeline {
    agent any

    environment {
        IMAGE_NAME = "devops-app"
        CONTAINER_NAME = "devops-container"
        PORT = "8085"
    }

    stages {
        stage('Checkout Code') {
            steps {
                git credentialsId: 'github-ssh-key', url: 'git@github.com:sforsandip/devops-html-webpage.git'
                sh 'ls -la'
            }
        }
    stages {

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t devops-app app'
            }
        }

        stage('Clean Old Container') {
            steps {
                sh '''
                docker ps -q --filter "publish=8085" | xargs -r docker rm -f
                '''
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                docker run -d -p 8085:80 --name devops-container devops-app
                '''
            }
        }
    }
}
