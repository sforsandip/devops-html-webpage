pipeline {
    agent any

    environment {
        IMAGE_NAME = "devops-app"
        CONTAINER_NAME = "devops-container"
        PORT = "8085"
    }

        stage{
		stage('Build Docker Image') {
            steps {
                sh 'docker build -t devops-app app'
            }
        }

        stage('Clean Old Container') {
            steps {
                sh '''
                docker ps -q --filter "publish=8085" | xargs -r docker rm -f
                '''
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                docker run -d -p 8085:80 --name devops-container devops-app
                '''
            }
        }
    }
}
